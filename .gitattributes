# Auto-detect text files
* text=auto eol=lf

# Force LF for source code
*.py       text eol=lf
*.pyi      text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.cfg      text eol=lf
*.ini      text eol=lf
*.sh       text eol=lf

# Binary files
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.tar      binary
*.gz      binary
*.sqlite3  binary
*.db       binary

# License file: keep as-is
/LICENSE   text eol=lf
